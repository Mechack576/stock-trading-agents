# OpenAI (required for default model; also used as fallback)
OPENAI_API_KEY=your_openai_api_key

# Alternative LLM providers (optional — use whichever you prefer)
DEEPSEEK_API_KEY=your_deepseek_api_key
GOOGLE_API_KEY=your_google_api_key
GROK_API_KEY=your_grok_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# Polygon.io — market data
# Leave blank for free end-of-day data, set to "paid" for 15-min delay, "realtime" for live quotes
POLYGON_API_KEY=your_polygon_api_key
POLYGON_PLAN=free   # free | paid | realtime

# Brave Search — used by the Researcher agent
BRAVE_API_KEY=your_brave_api_key

# Pushover — push notifications after each trade cycle
PUSHOVER_USER=your_pushover_user_key
PUSHOVER_TOKEN=your_pushover_app_token
